# Airflow secret key for session signing — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=replace-with-generated-value

# Fernet key for encrypting connection passwords — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace-with-generated-value

# Databricks connection — filled in once Databricks workspace is set up
DATABRICKS_HOST=
DATABRICKS_TOKEN=
